{
  "entities": {
    "User": {
      "title": "User",
      "description": "Customer or Admin account data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "requiresPasswordReset": { "type": "boolean" },
        "savedMeasurements": {
          "type": "object",
          "properties": {
            "fullLength": { "type": "string" },
            "bust": { "type": "string" },
            "waist": { "type": "string" },
            "hips": { "type": "string" },
            "shoulderToWaist": { "type": "string" },
            "shoulderToShoulder": { "type": "string" },
            "sleeveLength": { "type": "string" },
            "roundSleeve": { "type": "string" },
            "neckCircumference": { "type": "string" }
          }
        }
      },
      "required": ["name", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "Bespoke garment order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "measurements": { "type": "object" },
        "productPrice": { "type": "number" },
        "productPaymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "shippingFee": { "type": "number" },
        "shippingPaymentStatus": { "type": "string", "enum": ["pending", "paid", "not_applicable"] },
        "orderStatus": {
          "type": "string",
          "enum": ["payment_confirmed", "in_progress", "ready_for_shipping", "shipped"]
        },
        "expectedCompletionDate": { "type": "string", "format": "date-time" },
        "expectedDeliveryDate": { "type": "string", "format": "date-time" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "measurements", "productPrice", "productPaymentStatus", "orderStatus", "createdAt", "updatedAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Available bespoke designs",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array" },
        "category": { "type": "string" }
      },
      "required": ["name", "price"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app alerts for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "orderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and settings"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Garment orders"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Bespoke catalog"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/admins/{adminId}": {
      "schema": { "type": "object", "properties": { "uid": { "type": "string" } } },
      "description": "Admin access list"
    }
  }
}
